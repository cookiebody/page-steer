{
    "name": "@page-steer/llms",
    "version": "0.9.0",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        }
    },
    "publishConfig": {
        "main": "./dist/lib/page-steer-llms.js",
        "module": "./dist/lib/page-steer-llms.js",
        "types": "./dist/lib/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/lib/index.d.ts",
                "import": "./dist/lib/page-steer-llms.js",
                "default": "./dist/lib/page-steer-llms.js"
            }
        }
    },
    "files": [
        "dist/"
    ],
    "description": "LLM client with reflection-before-action mental model for page-steer",
    "keywords": [
        "page-steer",
        "llm",
        "openai",
        "tool-calling",
        "agent"
    ],
    "author": "CookieBody",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/cookiebody/PageSteer.git",
        "directory": "packages/llms"
    },
    "homepage": "https://cookiebody.github.io/docs/page-steer/",
    "scripts": {
        "build": "vite build",
        "test": "vitest run",
        "prepublishOnly": "node ../../scripts/pre-publish.js",
        "postpublish": "node ../../scripts/post-publish.js"
    },
    "dependencies": {
        "chalk": "^5.6.2"
    },
    "peerDependencies": {
        "zod": "^3.25.0 || ^4.0.0"
    },
    "devDependencies": {
        "zod": "^4.4.3"
    }
