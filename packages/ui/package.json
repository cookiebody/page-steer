{
    "name": "@page-steer/ui",
    "version": "0.9.0",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        }
    },
    "publishConfig": {
        "main": "./dist/lib/page-steer-ui.js",
        "module": "./dist/lib/page-steer-ui.js",
        "types": "./dist/lib/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/lib/index.d.ts",
                "import": "./dist/lib/page-steer-ui.js",
                "default": "./dist/lib/page-steer-ui.js"
            }
        }
    },
    "files": [
        "dist/"
    ],
    "description": "UI components for page-steer - Panel and i18n",
    "keywords": [
        "page-steer",
        "ui",
        "panel",
        "i18n"
    ],
    "author": "CookieBody",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/cookiebody/PageSteer.git",
        "directory": "packages/ui"
    },
    "homepage": "https://cookiebody.github.io/docs/page-steer/",
    "scripts": {
        "build": "vite build",
        "prepublishOnly": "node ../../scripts/pre-publish.js",
        "postpublish": "node ../../scripts/post-publish.js"
    }
}
